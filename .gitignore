# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log

# NOTE: data/ IS committed on purpose — the bundled snapshot CSV + IndexMapping.json
# are what a hosted Vistas serves (free cloud hosts usually can't reach the NSE API).
# If snapshots pile up, keep only the newest "Indices Data TR till *.csv".

# Generated offline decks (large, regenerated on every data update / Save button)
output/

# GitHub-Pages publish clone — a SEPARATE git repo (own .git + remote) that holds the
# live passive/ + terminal/ site. Lives here so everything Vistas is self-contained, but
# is its OWN repo, so the dev repo must never track it. publish_*.py default to ./_pages.
_pages/

# Parity-harness scratch (regenerate with: python _parity_dump.py)
_parity/

# Bhavcopy raw-zip cache (verbatim exchange files, fetch-once, large + regenerable).
# The assembled stock panel CSV in data/ is what ships; these zips are just the source.
data/_bhavzip/
data/_bhavcache/

# AMC monthly-portfolio raw-workbook cache (verbatim XLSX/XLS, fetch-once-a-month, regenerable).
# The parsed per-scheme JSON in data/funds/portfolio is what ships; these are just the source.
data/funds/portfolio_cache/

# Daily-refresh run reports (operational logs written by vistas/pipeline.py — local only).
data/_refresh/

# Monthly self-contained portfolio-history dumps (vistas/portfolio_dump.py). Large (~60MB)
# and regenerable from holdings_history.parquet; a fresh cumulative folder is produced each
# month, so keep them out of the dev repo. Hand-around/archival artifact, not source.
All_funds_portfolio_*/

# LICENSED / GATED layer — paid third-party IP (LSEG StarMine, Bloomberg). NEVER committed,
# NEVER published. Lives local-only / private-auth host. See VISTAS_DATA_INTEGRATION_PLAN.md §0.
vistas_gated/
data/_gated/

# ARM repository — raw LSEG StarMine ARM parquet (licensed IP, ~1GB+ and growing weekly): the
# historical dump + weekly drops + the compiled India cache. NEVER committed (licensed; huge).
# Only the trimmed, ABSL-signed-off ARM *cards* baked into the per-stock fundamentals JSON ship.
# Relocatable via $VISTAS_ARM_DIR. See vistas/arm.py.
arm_repo/

# ───────── vistas-codebase repo (2026-06-26): keep CODE, exclude heavy/regenerable data ─────────
# Node deps — regenerate with `npm install`.
node_modules/

# HEAVY stock panels (130–185 MB each) — GitHub hard-rejects >100 MB; all rebuildable via the
# bhavcopy fetchers. (The small ~5 MB INDEX TR snapshot `data/Indices Data TR till *.csv` IS kept
# as the seed — these patterns target the STOCK panels only.)
data/Stocks Data*.csv
data/legacy_mcap_daily.csv

# Funds holdings history (large parquet) + its backup — rebuilt from the portfolio fetch.
data/funds/history/*.parquet
data/funds/history/*.parquet.bak

# Raw fetch staging + generated exports — regenerable.
data/_raw/
export/

# Baked screen/site JSON that belongs to the build output (regenerated by publish_terminal.py).
data/_screens/

# Disabled accidental home repo backup (if it ever lands inside a project tree).
.git_DISABLED_*/

# Third-party COPYRIGHTED research (broker / sell-side PDFs) — NOT code, NOT for redistribution.
Sell Side Research Reports/

# Stray fetch/scrape debugging artifacts (raw vendor HTML/JS/zip dumps captured during data pulls).
_scratch_quant/
uti_*
samco_*
*_dump.html
*_landing.html
*_portfolio.html
*_probe/
